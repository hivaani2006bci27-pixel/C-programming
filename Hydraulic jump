#include <stdio.h>
#include <math.h>
int main() 
{
    float y1, v1, g = 9.81, Fr1, y2;
    printf("Enter initial depth y1 (m) and velocity v1 (m/s): ");
    scanf("%f %f", &y1, &v1);
    Fr1 = v1 / sqrt(g * y1);

    if (Fr1 <= 1.0) 
    {
        printf("Jump not possible: Flow is not supercritical.\n");
    }
    else 
    {
        y2 = (y1 / 2.0) * (sqrt(1 + 8 * Fr1 * Fr1) - 1);
        printf("Conjugate Depth y2: %.3f m\n", y2);
        printf("Energy Loss: %.3f m\n", pow(y2 - y1, 3) / (4 * y1 * y2));
    }
    return 0;
}
